# Docker Compose environment file

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=tos_analyzer

# App Config
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:your_password_here@db:5432/tos_analyzer?sslmode=disable

# Secrets (REQUIRED — app will fail to start if SECRET_KEY is missing)
SECRET_KEY=change-this-to-a-real-secret
CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
