# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Set to "production" in Render Dashboard
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Neon connection string format:
# postgresql://username:password@host/dbname?sslmode=require
#
# Local development example:
# DATABASE_URL=postgresql://user:password@localhost:5432/tos_analyzer
#
# Neon example (copy from Neon dashboard):
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# Comma-separated list of allowed frontend origins
# Example: https://your-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Optional API rate limiter settings
API_RATE_LIMIT_MAX_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Secrets (DO NOT commit - set in Render Dashboard for production)
# ---------------------------------------------------------------------------
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Get your Cerebras key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your-cerebras-api-key-here

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Frontend URL (Required for production CORS)
# ---------------------------------------------------------------------------
# Development: http://localhost:5173
# Production: https://tos-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
