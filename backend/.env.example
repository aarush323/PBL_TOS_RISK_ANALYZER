# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
# Get your Cerebras key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your-cerebras-api-key-here

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname
# The app will automatically convert 'postgresql://' to 'postgresql+asyncpg://'
DATABASE_URL=postgresql://user:password@localhost:5432/tos_analyzer

# Comma-separated list of allowed frontend origins
# Example: https://your-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Optional API rate limiter settings
API_RATE_LIMIT_MAX_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# JWT Authentication Settings
# ---------------------------------------------------------------------------
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# SMTP Configuration (For Email Verification)
# ---------------------------------------------------------------------------
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
