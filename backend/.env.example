# ─── Environment ───
# Set to "production" in deployment. Defaults to "development" for local dev.
ENVIRONMENT=development

# ─── Database ───
# PostgreSQL connection string. Required in production.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/tos_analyzer?sslmode=require

# ─── CORS ───
# Comma-separated list of allowed frontend origins for CORS.
# In production, set this to your frontend domain.
# Example: https://your-frontend.up.railway.app
# Falls back to FRONTEND_URL if not set, then localhost defaults.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend URL ───
# Used for CORS in production. Must match your deployed frontend domain.
FRONTEND_URL=http://localhost:5173

# ─── Secrets (DO NOT commit - use secret manager in production) ───
# Generate a secure key: openssl rand -hex 32
# REQUIRED — app will fail to start if missing.
SECRET_KEY=change-this-to-a-real-secret

# Cerebras API key for LLM inference. Optional if Groq is configured instead.
CEREBRAS_API_KEY=

# Groq API key (alternative to Cerebras). Optional if Cerebras is configured.
GROQ_API_KEY=

# Gemini API key for embeddings. Required for RAG indexing.
GEMINI_API_KEY=

# ─── JWT ───
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Rate Limiting (optional) ───
API_RATE_LIMIT_MAX_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
