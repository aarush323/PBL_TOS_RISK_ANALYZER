        </div>

        {/* Deep AI Lane */}
        <div className="flex-1">
          <div className="flex items-center gap-2 mb-1.5">
            <div className="w-2 h-2 rounded-full bg-[#007AFF]" />
            <span className="text-xs text-white/60">Deep AI (Cerebras)</span>
